<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Kugelblitz ACP Server"
           Manufacturer="Kugelblitz"
           Version="0.1.0"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Kugelblitz">
        <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <File Id="acp_server.exe"
                Source="acp_server.exe"
                KeyPath="yes" />
          <Environment Id="PathEnv"
                       Action="set"
                       Name="PATH"
                       Part="last"
                       System="yes"
                       Value="[INSTALLFOLDER]" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentRef Id="MainExecutable" />
    </Feature>
  </Package>
</Wix>
